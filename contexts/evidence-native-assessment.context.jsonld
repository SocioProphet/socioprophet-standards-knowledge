{
  "@context": {
    "@version": 1.1,
    "sp": "https://socioprophet.ai/ns/assessment#",
    "id": "@id",
    "type": "@type",

    "EvidenceRef": "sp:EvidenceRef",
    "Claim": "sp:Claim",
    "ClaimConflict": "sp:ClaimConflict",
    "ControlRequirement": "sp:ControlRequirement",
    "ControlCellEvaluation": "sp:ControlCellEvaluation",
    "Finding": "sp:Finding",
    "AssessmentReceipt": "sp:AssessmentReceipt",
    "AssessmentReport": "sp:AssessmentReport",

    "evidenceRefId": "sp:evidenceRefId",
    "claimId": "sp:claimId",
    "conflictId": "sp:conflictId",
    "controlRequirementId": "sp:controlRequirementId",
    "evaluationId": "sp:evaluationId",
    "findingId": "sp:findingId",
    "receiptId": "sp:receiptId",
    "reportId": "sp:reportId",

    "sourceSystem": "sp:sourceSystem",
    "sourceUri": { "@id": "sp:sourceUri", "@type": "@id" },
    "contentDigest": "sp:contentDigest",
    "digestAlg": "sp:digestAlg",
    "digestValue": "sp:digestValue",
    "locator": "sp:locator",
    "locatorType": "sp:locatorType",
    "tableName": "sp:tableName",
    "rowKey": "sp:rowKey",
    "cellRange": "sp:cellRange",
    "jsonPointer": "sp:jsonPointer",
    "rawLocator": "sp:rawLocator",

    "subject": "sp:subject",
    "predicate": "sp:predicate",
    "object": "sp:object",
    "modality": "sp:modality",
    "confidence": { "@id": "sp:confidence", "@type": "http://www.w3.org/2001/XMLSchema#decimal" },
    "normalizedText": "sp:normalizedText",
    "claimType": "sp:claimType",

    "leftClaimRef": { "@id": "sp:leftClaimRef", "@type": "@id" },
    "rightClaimRef": { "@id": "sp:rightClaimRef", "@type": "@id" },
    "controlRequirementRef": { "@id": "sp:controlRequirementRef", "@type": "@id" },
    "evaluationRef": { "@id": "sp:evaluationRef", "@type": "@id" },
    "receiptRef": { "@id": "sp:receiptRef", "@type": "@id" },

    "frameworkId": "sp:frameworkId",
    "frameworkVersion": "sp:frameworkVersion",
    "controlId": "sp:controlId",
    "rowId": "sp:rowId",
    "requiredProofClass": "sp:requiredProofClass",
    "decisionPolicy": "sp:decisionPolicy",

    "traceId": "sp:traceId",
    "status": "sp:status",
    "decision": "sp:decision",
    "supportingEvidenceRef": { "@id": "sp:supportingEvidenceRef", "@type": "@id" },
    "missingProofClass": "sp:missingProofClass",
    "claimRef": { "@id": "sp:claimRef", "@type": "@id" },
    "conflictRef": { "@id": "sp:conflictRef", "@type": "@id" },
    "exceptionRef": { "@id": "sp:exceptionRef", "@type": "@id" },
    "incidentRef": { "@id": "sp:incidentRef", "@type": "@id" },
    "rationale": "sp:rationale",

    "severity": "sp:severity",
    "disposition": "sp:disposition",
    "remediationSummary": "sp:remediationSummary",
    "closureCriterion": "sp:closureCriterion",
    "ownerRef": { "@id": "sp:ownerRef", "@type": "@id" },
    "dueAt": { "@id": "sp:dueAt", "@type": "http://www.w3.org/2001/XMLSchema#dateTime" },
    "createdAt": { "@id": "sp:createdAt", "@type": "http://www.w3.org/2001/XMLSchema#dateTime" },

    "assessmentScope": "sp:assessmentScope",
    "subjectId": "sp:subjectId",
    "subjectKind": "sp:subjectKind",
    "policyBundleId": "sp:policyBundleId",
    "policyBundleVersion": "sp:policyBundleVersion",
    "evaluatorVersion": "sp:evaluatorVersion",
    "replayManifestRef": { "@id": "sp:replayManifestRef", "@type": "@id" },
    "bundleRef": { "@id": "sp:bundleRef", "@type": "@id" },
    "replayable": { "@id": "sp:replayable", "@type": "http://www.w3.org/2001/XMLSchema#boolean" },
    "sealedAt": { "@id": "sp:sealedAt", "@type": "http://www.w3.org/2001/XMLSchema#dateTime" },
    "generatedAt": { "@id": "sp:generatedAt", "@type": "http://www.w3.org/2001/XMLSchema#dateTime" },

    "coveragePercent": { "@id": "sp:coveragePercent", "@type": "http://www.w3.org/2001/XMLSchema#decimal" },
    "passCount": { "@id": "sp:passCount", "@type": "http://www.w3.org/2001/XMLSchema#integer" },
    "partialCount": { "@id": "sp:partialCount", "@type": "http://www.w3.org/2001/XMLSchema#integer" },
    "failCount": { "@id": "sp:failCount", "@type": "http://www.w3.org/2001/XMLSchema#integer" },
    "warnCount": { "@id": "sp:warnCount", "@type": "http://www.w3.org/2001/XMLSchema#integer" },
    "findingCount": { "@id": "sp:findingCount", "@type": "http://www.w3.org/2001/XMLSchema#integer" },
    "evidenceCount": { "@id": "sp:evidenceCount", "@type": "http://www.w3.org/2001/XMLSchema#integer" },

    "localityClass": "sp:localityClass",
    "confidentiality": "sp:confidentiality",
    "retentionPolicyRef": { "@id": "sp:retentionPolicyRef", "@type": "@id" }
  }
}
