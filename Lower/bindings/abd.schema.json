{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Binding Descriptor v0.1",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "bindings"],
  "properties": {
    "apiVersion": {"const": "bindings.socioprophet.io/v0.1"},
    "kind": {"const": "AgentBindingDescriptor"},
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      },
      "additionalProperties": true
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": {"enum": ["port", "device", "socket"]},
          "name": {"type": "string", "minLength": 1},
          "portNumber": {"type": "integer", "minimum": 1, "maximum": 65535},
          "devicePath": {"type": "string", "pattern": "^/dev/"},
          "ioClaim": {"type": "string", "minLength": 1},
          "socketPath": {"type": "string", "pattern": "^(/run/|/var/run/)"}
        },
        "additionalProperties": true,
        "allOf": [
          {"if": {"properties": {"type": {"const": "port"}}}, "then": {"required": ["portNumber"]}},
          {"if": {"properties": {"type": {"const": "device"}}}, "then": {"required": ["devicePath", "ioClaim"]}},
          {"if": {"properties": {"type": {"const": "socket"}}}, "then": {"required": ["socketPath"]}}
        ]
      }
    }
  },
  "additionalProperties": false
}
