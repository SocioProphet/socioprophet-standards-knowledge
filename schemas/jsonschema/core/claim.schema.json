{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "socioprophet://schemas/knowledge/core/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim_id", "statement", "created_at", "assertion"],
  "properties": {
    "claim_id": { "type": "string" },
    "statement": { "type": "string", "minLength": 1 },
    "claim_type": { "type": "string", "enum": ["fact", "hypothesis", "definition", "plan", "requirement", "risk", "decision"], "default": "fact" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvidenceRef" },
      "default": []
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asserted_by", "asserted_at"],
      "properties": {
        "asserted_by": { "$ref": "socioprophet://schemas/knowledge/common/actor_ref.schema.json" },
        "asserted_at": { "type": "string", "format": "date-time" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
        "method": { "type": "string", "description": "authored | extracted | inferred | imported" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["proposed", "contested", "validated", "rejected"], "default": "proposed" },
        "quorum_required": { "type": "integer", "minimum": 1, "default": 1 },
        "validators": { "type": "array", "items": { "$ref": "socioprophet://schemas/knowledge/common/actor_ref.schema.json" }, "default": [] },
        "validated_at": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "array",
      "items": { "$ref": "socioprophet://schemas/knowledge/common/provenance_ref.schema.json" },
      "default": []
    }
  },
  "$defs": {
    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["anchor", "dataset", "log", "citation", "bundle"] },
        "anchor": { "$ref": "socioprophet://schemas/knowledge/core/anchor.schema.json" },
        "artifact": { "$ref": "socioprophet://schemas/knowledge/common/artifact_ref.schema.json" },
        "citation_key": { "type": "string" },
        "commentary": { "type": "string" }
      }
    }
  }
}
