{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "socioprophet://schemas/knowledge/core/mention.schema.json",
  "title": "Mention",
  "type": "object",
  "additionalProperties": false,
  "required": ["mention_id", "passage", "entity", "surface_form", "confidence", "created_at"],
  "properties": {
    "mention_id": { "type": "string" },
    "passage": { "$ref": "socioprophet://schemas/knowledge/core/node_ref.schema.json" },
    "entity": { "$ref": "socioprophet://schemas/knowledge/core/node_ref.schema.json" },
    "surface_form": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "selector": { "$ref": "socioprophet://schemas/knowledge/core/selector.schema.json" },
    "provenance": { "type": "array", "items": { "$ref": "socioprophet://schemas/knowledge/common/provenance_ref.schema.json" }, "default": [] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
