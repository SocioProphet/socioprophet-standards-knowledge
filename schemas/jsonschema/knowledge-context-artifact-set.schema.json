{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/knowledge/knowledge-context-artifact-set.v0.1.schema.json",
  "title": "KnowledgeContextArtifactSet",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "id", "sourceStandard", "artifacts"],
  "properties": {
    "kind": {
      "const": "KnowledgeContextArtifactSet"
    },
    "version": {
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "sourceStandard": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/KnowledgeContextArtifact"
      }
    }
  },
  "$defs": {
    "KnowledgeContextArtifact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "Note",
            "Claim",
            "Annotation",
            "MeriotopographicEdge",
            "ProvenanceRecord"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "Note" } } },
          "then": {
            "required": ["title", "body", "provenanceRef"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "body": { "type": "string", "minLength": 1 },
              "provenanceRef": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "Claim" } } },
          "then": {
            "required": ["assertion", "validationState", "evidenceRefs", "provenanceRef"],
            "properties": {
              "assertion": { "type": "string", "minLength": 1 },
              "validationState": { "type": "string", "minLength": 1 },
              "evidenceRefs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "provenanceRef": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "Annotation" } } },
          "then": {
            "required": ["targetRef", "selector", "body"],
            "properties": {
              "targetRef": { "type": "string", "minLength": 1 },
              "selector": {
                "type": "object",
                "required": ["type", "exact"],
                "properties": {
                  "type": { "type": "string", "minLength": 1 },
                  "exact": { "type": "string", "minLength": 1 }
                }
              },
              "body": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "MeriotopographicEdge" } } },
          "then": {
            "required": ["subjectRef", "predicate", "objectRef"],
            "properties": {
              "subjectRef": { "type": "string", "minLength": 1 },
              "predicate": {
                "type": "string",
                "enum": ["derives_from", "redacted_by", "anchors_to"]
              },
              "objectRef": { "type": "string", "minLength": 1 },
              "governanceRefs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "const": "ProvenanceRecord" } } },
          "then": {
            "required": ["activity", "inputs", "outputs", "removedClasses", "policyRefs"],
            "properties": {
              "activity": { "type": "string", "minLength": 1 },
              "inputs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "outputs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "removedClasses": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "policyRefs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      ]
    }
  }
}
