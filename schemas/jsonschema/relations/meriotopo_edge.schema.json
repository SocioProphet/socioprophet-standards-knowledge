{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "socioprophet://schemas/knowledge/relations/meriotopo_edge.schema.json",
  "title": "MeriotopographicEdge",
  "type": "object",
  "additionalProperties": false,
  "required": ["edge_id", "subject", "predicate", "object", "assertion"],
  "properties": {
    "edge_id": { "type": "string" },
    "subject": { "$ref": "#/$defs/NodeRef" },
    "predicate": {
      "type": "string",
      "anyOf": [
        { "enum": [
          "part_of", "has_part",
          "member_of", "contains",
          "located_in", "adjacent_to", "overlaps",
          "derives_from", "references", "cites",
          "supports", "contradicts",
          "anchors_to",
          "asserted_by", "validated_by", "attested_by",
          "redacted_by", "masked_by"
        ]},
        { "pattern": "^x-[a-z0-9._-]+$" }
      ]
    },
    "object": { "$ref": "#/$defs/NodeRef" },
    "qualifiers": { "type": "object", "additionalProperties": true, "default": {} },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asserted_by", "asserted_at"],
      "properties": {
        "asserted_by": { "$ref": "socioprophet://schemas/knowledge/common/actor_ref.schema.json" },
        "asserted_at": { "type": "string", "format": "date-time" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
        "method": { "type": "string", "description": "authored | extracted | inferred | imported" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["proposed", "contested", "validated", "rejected"], "default": "proposed" },
        "quorum_required": { "type": "integer", "minimum": 1, "default": 1 },
        "validators": { "type": "array", "items": { "$ref": "socioprophet://schemas/knowledge/common/actor_ref.schema.json" }, "default": [] },
        "validated_at": { "type": "string", "format": "date-time" }
      }
    },
    "provenance": {
      "type": "array",
      "items": { "$ref": "socioprophet://schemas/knowledge/common/provenance_ref.schema.json" },
      "default": []
    }
  },
  "$defs": {
    "NodeRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_type", "ref"],
      "properties": {
        "node_type": { "type": "string", "enum": ["artifact", "note", "claim", "annotation", "entity", "workspace", "bundle"] },
        "ref": { "type": "string" },
        "anchor": { "$ref": "socioprophet://schemas/knowledge/core/anchor.schema.json" }
      }
    }
  }
}
