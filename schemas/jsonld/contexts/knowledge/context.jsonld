{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://socioprophet.org/ns/knowledge#",
    "spk": "https://socioprophet.org/ns/knowledge#",
    "prov": "http://www.w3.org/ns/prov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type",

    "note_id": { "@id": "spk:note_id" },
    "claim_id": { "@id": "spk:claim_id" },
    "annotation_id": { "@id": "spk:annotation_id" },
    "edge_id": { "@id": "spk:edge_id" },

    "title": { "@id": "spk:title" },
    "body": { "@id": "spk:body" },
    "format": { "@id": "spk:format" },
    "tags": { "@id": "spk:tag", "@container": "@set" },
    "aliases": { "@id": "spk:alias", "@container": "@set" },

    "created_at": { "@id": "prov:generatedAtTime", "@type": "xsd:dateTime" },
    "updated_at": { "@id": "spk:updated_at", "@type": "xsd:dateTime" },

    "artifact": { "@id": "spk:artifact" },
    "artifact_id": { "@id": "spk:artifact_id" },
    "content_hash": { "@id": "spk:content_hash" },
    "uri": { "@id": "spk:uri" },

    "anchor": { "@id": "spk:anchor" },
    "selector": { "@id": "spk:selector" },
    "stable_fragment": { "@id": "spk:stable_fragment" },

    "subject": { "@id": "spk:subject" },
    "object": { "@id": "spk:object" },

    "predicate": { "@id": "spk:predicate", "@type": "@vocab" },

    "assertion": { "@id": "spk:assertion" },
    "asserted_by": { "@id": "spk:asserted_by" },
    "asserted_at": { "@id": "spk:asserted_at", "@type": "xsd:dateTime" },
    "confidence": { "@id": "spk:confidence", "@type": "xsd:double" },
    "method": { "@id": "spk:method" },

    "validation": { "@id": "spk:validation" },
    "status": { "@id": "spk:status", "@type": "@vocab" },
    "quorum_required": { "@id": "spk:quorum_required", "@type": "xsd:integer" },
    "validators": { "@id": "spk:validator", "@container": "@set" },
    "validated_at": { "@id": "spk:validated_at", "@type": "xsd:dateTime" }
  }
}