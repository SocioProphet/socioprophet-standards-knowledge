{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Masonmark fixture corpus",
  "type": "object",
  "required": ["pack_version", "family_id", "fixtures", "acceptance_gate"],
  "properties": {
    "pack_version": {"type": "string"},
    "family_id": {"type": "string"},
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["fixture_id", "schema_id", "class", "utterance", "expected_decision"],
        "properties": {
          "fixture_id": {"type": "string"},
          "schema_id": {"type": "string"},
          "class": {"enum": ["positive", "abstain", "robustness"]},
          "utterance": {"type": "string"},
          "expected_decision": {"enum": ["promote", "abstain"]},
          "expected_view": {"type": "string"},
          "expected_ops": {"type": "array", "items": {"type": "string"}},
          "abstain_reason": {"type": ["array", "null"], "items": {"type": "string"}},
          "assertions": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "acceptance_gate": {"type": "object"}
  },
  "additionalProperties": false
}
